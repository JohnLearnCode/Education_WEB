# Server Configuration
PORT=3000
NODE_ENV=development
API_PROTOCOL=http
API_HOST=localhost

# Database Configuration
MONGODB_URL=mongodb://localhost:27017
DB_NAME=education_platform

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
ACCESS_TOKEN_SECRET=your-access-token-secret-change-in-production
REFRESH_TOKEN_SECRET=your-refresh-token-secret-change-in-production

# Optional: Cloudinary (for avatar uploads)
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# SePay Payment Gateway Configuration
# Get credentials from: https://sepay.vn
SEPAY_ENV=sandbox
SEPAY_MERCHANT_ID=your-sepay-merchant-id
SEPAY_SECRET_KEY=your-sepay-secret-key

# Frontend URLs (for payment callbacks)
FRONTEND_PROTOCOL=http
FRONTEND_HOST=localhost
FRONTEND_PORT=3000

# Redis Configuration
REDIS_URL=redis://localhost:6379

# Video Processing Configuration
VIDEO_TEMP_DIR=./temp/uploads
HLS_OUTPUT_DIR=./temp/hls
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
